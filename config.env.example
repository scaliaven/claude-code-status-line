# Claude Code Status Line — configuration
# Copy to ~/.config/claude-status-line/config.env and edit as needed.
# All values shown are defaults.

# Weekly token budget. Matches Claude Pro/Max weekly limits.
# Common values: 1000000 (1M), 5000000 (5M), 10000000 (10M)
WEEKLY_TOKEN_LIMIT=1000000

# Width of each progress bar (in block characters)
PROGRESS_BAR_WIDTH=10

# Show USD cost of the current session? (true/false)
SHOW_COST=true

# Maximum length of cwd before truncation
MAX_CWD_LEN=30
